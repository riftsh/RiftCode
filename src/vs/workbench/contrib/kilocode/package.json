{
  "name": "rift-ai",
  "displayName": "RiftAI: AI Coding Agent, Copilot, and Autocomplete",
  "description": "Open Source AI coding agent that generates code from natural language, automates tasks, and runs terminal commands. Features inline autocomplete, browser automation, automated refactoring, and custom modes for planning, coding, and debugging. Supports 500+ AI models including Claude (Anthropic), Gemini, Grok, GPT, Codex and GLM.",
  "version": "7.3.18",
  "icon": "assets/icons/logo-outline-black.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "publisher": "riftcode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kilo-Org/riftcode.git",
    "directory": "packages/kilo-vscode"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "license": "MIT",
  "author": {
    "name": "RiftAI"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "kilo",
    "RiftAI",
    "riftcode",
    "ai",
    "agent",
    "agentic",
    "coding",
    "coding agent",
    "coding assistant",
    "autocomplete",
    "code completion",
    "pair programming",
    "chat",
    "terminal",
    "chatgpt",
    "claude",
    "sonnet",
    "anthropic",
    "openai",
    "zoo code"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "kilo-worktree-setup",
        "properties": {
          "script": {
            "type": "string",
            "description": "The setup script command to execute"
          }
        }
      }
    ],
    "icons": {
      "kilo-logo": {
        "description": "RiftAI logo",
        "default": {
          "fontPath": "assets/icons/rift-ai-icon-font.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rift-ai-ActivityBar",
          "title": "RiftAI",
          "icon": "assets/icons/rift-ai-light.png",
          "darkIcon": "assets/icons/rift-ai-dark.png"
        }
      ]
    },
    "views": {
      "rift-ai-ActivityBar": [
        {
          "type": "webview",
          "id": "rift-ai.SidebarProvider",
          "name": "RiftAI"
        }
      ]
    },
    "commands": [
      {
        "command": "rift-ai.new.plusButtonClicked",
        "title": "New Task",
        "icon": "$(add)"
      },
      {
        "command": "rift-ai.new.agentManagerOpen",
        "title": "Agent Manager",
        "icon": "$(organization)"
      },
      {
        "command": "rift-ai.new.kiloClawOpen",
        "title": "KiloClaw",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "rift-ai.new.marketplaceButtonClicked",
        "title": "Marketplace",
        "icon": "$(extensions)"
      },
      {
        "command": "rift-ai.new.historyButtonClicked",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "rift-ai.new.profileButtonClicked",
        "title": "Profile",
        "icon": "$(account)"
      },
      {
        "command": "rift-ai.new.settingsButtonClicked",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "rift-ai.new.sidebarTitle.plusButtonClicked",
        "title": "New Task",
        "icon": "$(add)"
