    "submenus": [
      {
        "id": "rift-ai.new.editorContextMenu",
        "label": "RiftAI"
      },
      {
        "id": "rift-ai.new.terminalContextMenu",
        "label": "RiftAI"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "rift-ai.new.sidebarTitle.plusButtonClicked",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.historyButtonClicked",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.agentManagerOpen",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.kiloClawOpen",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.marketplaceButtonClicked",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.profileButtonClicked",
          "when": "false"
        },
        {
          "command": "rift-ai.new.sidebarTitle.settingsButtonClicked",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "rift-ai.new.sidebarTitle.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.kiloClawOpen",
          "group": "navigation@3",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.marketplaceButtonClicked",
          "group": "navigation@4",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == rift-ai.SidebarProvider"
        },
        {
          "command": "rift-ai.new.sidebarTitle.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == rift-ai.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "rift-ai.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "rift-ai.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "rift-ai.new.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "rift-ai.new.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == rift-ai.new.TabPanel"
        },
        {
          "command": "rift-ai.new.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == rift-ai.new.TabPanel"
        },
        {
          "command": "rift-ai.new.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == rift-ai.new.TabPanel"
        },
        {
          "command": "rift-ai.new.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == rift-ai.new.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "rift-ai.new.editorContextMenu",
          "group": "1_riftcode"
        }
      ],
      "rift-ai.new.editorContextMenu": [
        {
          "command": "rift-ai.new.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "rift-ai.new.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "rift-ai.new.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "rift-ai.new.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "rift-ai.new.terminalContextMenu",
          "group": "2_riftcode"
        }
      ],
      "rift-ai.new.terminalContextMenu": [
        {
          "command": "rift-ai.new.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "rift-ai.new.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "rift-ai.new.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rift-ai.new.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "rift-ai.new.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "rift-ai.new.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "rift-ai.new.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "rift-ai.new.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "rift-ai.new.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "rift-ai.new.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel'"
      },
      {
        "command": "rift-ai.new.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "sideBarFocus && rift-ai.new.sidebarVisible || activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel' || activeWebviewPanelId == 'rift-ai.new.TabPanel'"
      },
      {
        "command": "rift-ai.new.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "sideBarFocus && rift-ai.new.sidebarVisible || activeWebviewPanelId == 'rift-ai.new.AgentManagerPanel' || activeWebviewPanelId == 'rift-ai.new.TabPanel'"
      },
      {
        "command": "rift-ai.new.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && rift-ai.new.autocomplete.hasSuggestions"
      },
      {
        "command": "rift-ai.new.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && riftcode.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "rift-ai.new.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && riftcode.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      },
      {
        "command": "rift-ai.new.autocomplete.nextEdit.acceptOrJump",
        "key": "tab",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && !suggestWidgetVisible && rift-ai.nextEdit.hasPendingSuggestion"
      },
      {
        "command": "rift-ai.new.autocomplete.nextEdit.dismiss",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && rift-ai.nextEdit.hasPendingSuggestion"
      }
    ],
